---
import MainLayout from "../../../layouts/MainLayout.astro";
---

<MainLayout
  title="AI Strategy Insights | Ragan Dynamics"
  description="Expert insights on AI strategy, AI transformation, AI roadmap, governance and ROI for Singapore businesses."
>

  <!-- Hero -->

  <section class="bg-gradient-to-br from-slate-900 via-blue-900 to-slate-900 py-24">

    <div class="mx-auto max-w-6xl px-6">

      <span class="rounded-full bg-blue-600 px-4 py-2 text-sm font-semibold text-white">
        AI Strategy
      </span>

      <h1 class="mt-8 max-w-4xl text-5xl font-black leading-tight text-white">

        AI Strategy & Digital Transformation Insights

      </h1>

      <p class="mt-8 max-w-3xl text-xl leading-9 text-slate-200">

        Learn how Singapore businesses are adopting Artificial Intelligence,
        building AI roadmaps, improving productivity and achieving measurable ROI.

      </p>

    </div>

  </section>



  <!-- Intro -->

  <section class="bg-white py-16">

    <div class="mx-auto max-w-5xl px-6">

      <h2 class="text-3xl font-bold text-slate-900">

        Practical AI Insights for Business Leaders

      </h2>

      <p class="mt-6 text-lg leading-8 text-slate-600">

        Our AI Strategy articles are written for SME founders,
        business owners and enterprise leaders looking to
        implement AI successfully.

      </p>

      <p class="mt-6 text-lg leading-8 text-slate-600">

        Rather than focusing on technology alone,
        we explore practical business outcomes,
        implementation strategies,
        governance and return on investment.

      </p>

    </div>

  </section>



  <!-- Articles -->

  <section class="bg-slate-50 py-20">

    <div class="mx-auto max-w-6xl px-6">

      <h2 class="text-3xl font-bold text-slate-900">

        Latest AI Strategy Articles

      </h2>

      <div class="mt-12 grid gap-8 lg:grid-cols-2">

        <!-- Article -->

        <article class="rounded-3xl bg-white p-8 shadow transition hover:-translate-y-1 hover:shadow-xl">

          <div class="text-sm font-semibold uppercase tracking-wide text-blue-600">

            AI Transformation

          </div>

          <h3 class="mt-4 text-2xl font-bold text-slate-900">

            7 AI Opportunities Every Singapore SME Should Explore in 2026

          </h3>

          <p class="mt-5 leading-8 text-slate-600">

            Discover practical AI opportunities that reduce costs,
            improve productivity and accelerate business growth.

          </p>

          <a

            href="/insights/7-ai-opportunities-singapore-smes"

            class="mt-8 inline-flex font-semibold text-blue-600 hover:text-blue-800"

          >

            Read Article →

          </a>

        </article>



        <!-- Placeholder -->

        <article class="rounded-3xl border-2 border-dashed border-slate-300 bg-white p-8">

          <div class="text-sm font-semibold uppercase tracking-wide text-slate-400">

            Coming Soon

          </div>

          <h3 class="mt-4 text-2xl font-bold text-slate-900">

            Building an AI Roadmap for SMEs

          </h3>

          <p class="mt-5 leading-8 text-slate-600">

            Learn how to prioritise AI initiatives,
            evaluate ROI and create a practical
            implementation roadmap.

          </p>

        </article>



        <article class="rounded-3xl border-2 border-dashed border-slate-300 bg-white p-8">

          <div class="text-sm font-semibold uppercase tracking-wide text-slate-400">

            Coming Soon

          </div>

          <h3 class="mt-4 text-2xl font-bold text-slate-900">

            AI Governance for Singapore Businesses

          </h3>

          <p class="mt-5 leading-8 text-slate-600">

            Security, compliance and responsible AI adoption.

          </p>

        </article>



        <article class="rounded-3xl border-2 border-dashed border-slate-300 bg-white p-8">

          <div class="text-sm font-semibold uppercase tracking-wide text-slate-400">

            Coming Soon

          </div>

          <h3 class="mt-4 text-2xl font-bold text-slate-900">

            Calculating AI ROI

          </h3>

          <p class="mt-5 leading-8 text-slate-600">

            Learn how organisations measure the business value
            of AI investments.

          </p>

        </article>

      </div>

    </div>

  </section>



  <!-- CTA -->

  <section class="bg-white py-20">

    <div class="mx-auto max-w-5xl rounded-3xl bg-gradient-to-r from-blue-600 to-blue-700 px-10 py-16 text-center">

      <h2 class="text-4xl font-black text-white">

        Find Your Highest ROI AI Opportunities

      </h2>

      <p class="mx-auto mt-6 max-w-3xl text-xl leading-9 text-blue-100">

        Complete our complimentary
        AI Transformation & ROI Assessment
        and discover where AI can create
        measurable business value.

      </p>

      <a

        href="/assessment"

        class="mt-10 inline-flex rounded-xl bg-white px-10 py-5 text-lg font-bold text-blue-700 transition hover:bg-slate-100"

      >

        Start Free AI Transformation Assessment

      </a>

    </div>

  </section>

</MainLayout>
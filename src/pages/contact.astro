---
import MainLayout from "../layouts/MainLayout.astro";
---


<MainLayout

title="Contact Ragan Dynamics | AI Consulting & Automation"

description="
Talk to Ragan Dynamics about AI consulting,
AI automation, AI products and enterprise AI solutions.
"

>


<section class="bg-slate-50 py-20">


<div class="mx-auto max-w-5xl px-6">


<div class="mb-12 text-center">


<h1
class="
text-4xl
font-black
text-slate-900
md:text-5xl
">

Start Your AI Transformation Journey

</h1>



<p
class="
mx-auto
mt-5
max-w-3xl
text-lg
leading-8
text-slate-600
">

Tell us about your business challenge.
Our AI specialists will help identify practical
and cost-effective AI solutions.

</p>


</div>





<div
class="
rounded-3xl
bg-white
p-8
shadow-xl
md:p-12
">



<form

id="contact-form"

class="space-y-6"

>



<div
class="
grid
gap-6
md:grid-cols-2
">



<div>


<label

for="name"

class="
mb-2
block
font-semibold
text-slate-700
">

Full Name

</label>


<input

id="name"

name="name"

placeholder="Enter your full name"

required

class="
w-full
rounded-xl
border
border-slate-300
px-5
py-4
outline-none
focus:border-blue-600
"

/>


</div>





<div>


<label

for="email"

class="
mb-2
block
font-semibold
text-slate-700
">

Business Email Address

</label>



<input

id="email"

name="email"

type="email"

placeholder="name@company.com"

required

class="
w-full
rounded-xl
border
border-slate-300
px-5
py-4
outline-none
focus:border-blue-600
"

/>


</div>


</div>







<div
class="
grid
gap-6
md:grid-cols-2
">



<div>


<label

for="company"

class="
mb-2
block
font-semibold
text-slate-700
">

Organisation / Company Name

</label>



<input

id="company"

name="company"

placeholder="Your organisation name"

class="
w-full
rounded-xl
border
border-slate-300
px-5
py-4
outline-none
focus:border-blue-600
"

/>


</div>







<div>


<label

for="phone"

class="
mb-2
block
font-semibold
text-slate-700
">

Contact Number

</label>



<div class="flex gap-3">



<select

id="countryCode"

name="countryCode"

class="
w-32
rounded-xl
border
border-slate-300
px-3
py-4
outline-none
focus:border-blue-600
"

>


<option value="+65" selected>
🇸🇬 +65
</option>


<option value="+60">
🇲🇾 +60
</option>


<option value="+91">
🇮🇳 +91
</option>


<option value="+86">
🇨🇳 +86
</option>


<option value="+61">
🇦🇺 +61
</option>


<option value="+44">
🇬🇧 +44
</option>


<option value="+1">
🇺🇸 +1
</option>


</select>





<input

id="phone"

name="phone"

placeholder="XXXX XXXX"

class="
flex-1
rounded-xl
border
border-slate-300
px-5
py-4
outline-none
focus:border-blue-600
"

/>



</div>



</div>


</div>
<div>


<label

for="service"

class="
mb-2
block
font-semibold
text-slate-700
">

How can we support your organisation?

</label>



<select

id="service"

name="service"

class="
w-full
rounded-xl
border
border-slate-300
px-5
py-4
outline-none
focus:border-blue-600
"

>


<option value="AI Strategy & Readiness">
AI Strategy & Readiness
</option>


<option value="Business Process Automation">
Business Process Automation
</option>


<option value="AI Customer Service">
AI Customer Service
</option>


<option value="AI Sales & Marketing">
AI Sales & Marketing
</option>


<option value="Business Intelligence">
Business Intelligence
</option>


<option value="Microsoft Copilot Solutions">
Microsoft Copilot Solutions
</option>


<option value="Cloud & AI Modernisation">
Cloud & AI Modernisation
</option>


<option value="AI Security & Governance">
AI Security & Governance
</option>


<option value="AI Training & Adoption">
AI Training & Adoption
</option>


<option value="Other Business Requirements">
Other Business Requirements
</option>


</select>


</div>





<div>


<label

for="message"

class="
mb-2
block
font-semibold
text-slate-700
">

Business Challenge / Requirements

</label>



<textarea

id="message"

name="message"

rows="6"

placeholder="Describe your business challenge, objectives or AI requirements"

required

class="
w-full
rounded-xl
border
border-slate-300
px-5
py-4
outline-none
focus:border-blue-600
"

></textarea>


</div>






<button

id="submit-button"

type="submit"

data-analytics="contact-form-submit"

class="
w-full
rounded-xl
bg-blue-600
px-8
py-4
font-bold
text-white
transition
hover:bg-blue-700
"

>

Submit Request

</button>



</form>





<p

id="result"

class="
mt-6
text-center
font-semibold
"

></p>




</div>


</div>


</section>





<script is:inline>

const form =
document.querySelector<HTMLFormElement>(
"#contact-form"
);


const result =
document.querySelector<HTMLElement>(
"#result"
);


const button =
document.querySelector<HTMLButtonElement>(
"#submit-button"
);



if(
form &&
result &&
button
){


form.addEventListener(
"submit",
async(event)=>{


event.preventDefault();



button.disabled=true;


button.textContent =
"Submitting...";



const formData =
new FormData(form);



const data =
Object.fromEntries(
formData
);



try{


const response =
await fetch(
"/api/contact",
{

method:"POST",

headers:
{

"Content-Type":
"application/json"

},

body:
JSON.stringify(data)

}

);



const json =
await response.json() as {

success?:boolean;

error?:string;

};



if(json.success){


result.textContent =
"Thank you. We will contact you shortly.";



result.className =
"mt-6 text-center font-semibold text-green-600";



form.reset();



if(window.cf?.track){


window.cf.track(
"contact-form-success"
);


}


}

else{


result.textContent =
json.error ??
"Unable to submit request.";



result.className =
"mt-6 text-center font-semibold text-red-600";


}



}

catch(error){


console.error(
error
);



result.textContent =
"An unexpected error occurred.";



result.className =
"mt-6 text-center font-semibold text-red-600";


}



finally{


button.disabled=false;


button.textContent =
"Submit Request";


}



}

);


}


</script>



</MainLayout>
---
import MainLayout from "../layouts/MainLayout.astro";
---

<MainLayout

title="Contact Ragan Dynamics | AI Consulting & Automation"

description="
Talk to Ragan Dynamics about AI consulting,
AI automation, AI products and enterprise AI solutions.
"

>


<section class="bg-slate-50 py-20">


<div class="mx-auto max-w-5xl px-6">


<div class="mb-12 text-center">


<h1
class="
text-4xl
font-black
text-slate-900
md:text-5xl
"
>
Start Your AI Transformation Journey
</h1>


<p
class="
mx-auto
mt-5
max-w-3xl
text-lg
leading-8
text-slate-600
"
>
Tell us about your business challenge.
Our AI specialists will help identify
practical and cost-effective AI solutions.
</p>


</div>




<div
class="
rounded-3xl
bg-white
p-8
shadow-xl
md:p-12
"
>


<form

id="contact-form"

class="space-y-6"

>



<div class="grid gap-6 md:grid-cols-2">



<div>

<label
for="name"
class="
mb-2
block
text-sm
font-semibold
text-slate-700
"
>
Name
</label>


<input

id="name"

name="name"

placeholder="Your Name"

required

class="
w-full
rounded-xl
border
border-slate-300
px-5
py-4
outline-none
focus:border-blue-600
"

/>

</div>




<div>

<label
for="email"
class="
mb-2
block
text-sm
font-semibold
text-slate-700
"
>
Email Address
</label>


<input

id="email"

name="email"

type="email"

placeholder="Email Address"

required

class="
w-full
rounded-xl
border
border-slate-300
px-5
py-4
outline-none
focus:border-blue-600
"

/>

</div>


</div>






<div class="grid gap-6 md:grid-cols-2">



<div>

<label
for="company"
class="
mb-2
block
text-sm
font-semibold
text-slate-700
"
>
Company Name
</label>


<input

id="company"

name="company"

placeholder="Company Name"

class="
w-full
rounded-xl
border
border-slate-300
px-5
py-4
outline-none
focus:border-blue-600
"

/>

</div>




<div>

<label
for="phone"
class="
mb-2
block
text-sm
font-semibold
text-slate-700
"
>
Phone Number
</label>


<input

id="phone"

name="phone"

type="tel"

placeholder="Phone Number"

class="
w-full
rounded-xl
border
border-slate-300
px-5
py-4
outline-none
focus:border-blue-600
"

/>

</div>


</div>






<div>


<label

for="service"

class="
mb-2
block
text-sm
font-semibold
text-slate-700
"

>
How can we help you?
</label>



<select

id="service"

name="service"

class="
w-full
rounded-xl
border
border-slate-300
px-5
py-4
outline-none
focus:border-blue-600
"

>


<option value="AI Strategy & Consulting">
AI Strategy & Consulting
</option>


<option value="AI Automation">
AI Automation
</option>


<option value="Generative AI Solutions">
Generative AI Solutions
</option>


<option value="Microsoft Copilot">
Microsoft Copilot
</option>


<option value="AI Chatbots & Virtual Assistants">
AI Chatbots & Virtual Assistants
</option>


<option value="AI Productivity Solutions">
AI Productivity Solutions
</option>


<option value="AI Governance & Security">
AI Governance & Security
</option>


<option value="Cloud AI Solutions">
Cloud AI Solutions
</option>


<option value="AI Training & Workshops">
AI Training & Workshops
</option>


<option value="AI Product Development">
AI Product Development
</option>


<option value="Other">
Other
</option>


</select>


</div>






<div>


<label

for="message"

class="
mb-2
block
text-sm
font-semibold
text-slate-700
"

>
Tell us about your project
</label>



<textarea

id="message"

name="message"

rows="6"

placeholder="Describe your AI requirements, challenges or goals"

required

class="
w-full
rounded-xl
border
border-slate-300
px-5
py-4
outline-none
focus:border-blue-600
"

></textarea>


</div>






<button

id="submit-button"

type="submit"

data-analytics="contact-form-submit"

class="
w-full
rounded-xl
bg-blue-600
px-8
py-4
font-bold
text-white
transition
hover:bg-blue-700
"

>
Send Enquiry
</button>




</form>






<p

id="result"

class="
mt-6
text-center
font-semibold
"

></p>




</div>


</div>


</section>







<script>


const form =
document.querySelector<HTMLFormElement>(
"#contact-form"
);


const result =
document.querySelector<HTMLElement>(
"#result"
);


const button =
document.querySelector<HTMLButtonElement>(
"#submit-button"
);




if(
form &&
result &&
button
){


form.addEventListener(
"submit",
async(event)=>{


event.preventDefault();



button.disabled=true;

button.textContent =
"Sending...";



const formData =
new FormData(form);



const data =
Object.fromEntries(
formData
);

console.log(data);


try{


const response =
await fetch(
"/api/contact",
{

method:"POST",

headers:
{

"Content-Type":
"application/json"

},

body:
JSON.stringify(data)

}
);




const json =
await response.json() as {

success?:boolean;

error?:string;

};




if(json.success){


result.textContent =
"Thank you. Our AI specialists will contact you shortly.";



result.className =
"mt-6 text-center font-semibold text-green-600";



form.reset();




if(window.cf?.track){


window.cf.track(
"contact-form-success"
);


}



}

else{


result.textContent =
json.error ??
"Unable to submit form.";



result.className =
"mt-6 text-center font-semibold text-red-600";


}



}


catch(error){


result.textContent =
"An unexpected error occurred.";


result.className =
"mt-6 text-center font-semibold text-red-600";


}



finally{


button.disabled=false;


button.textContent =
"Send Enquiry";


}



}

);


}


</script>



</MainLayout>
---
import MainLayout from "../layouts/MainLayout.astro";

import BusinessContact from "../components/contact/BusinessContact.astro";
---

<MainLayout
  title="About Ragan Dynamics"
  description="Learn how Ragan Dynamics helps Singapore SMEs adopt practical AI, automation and cloud technologies to improve business outcomes."
>

<section class="bg-slate-50 py-20">

  <div class="mx-auto max-w-5xl px-6 text-center">

    <span class="text-sm font-semibold uppercase tracking-widest text-blue-600">
      About Us
    </span>

    <h1 class="mt-6 text-5xl font-bold tracking-tight text-slate-900">

      Practical AI.
      Real Business Outcomes.

    </h1>

    <p class="mx-auto mt-8 max-w-3xl text-xl leading-9 text-slate-600">

      Ragan Dynamics helps organisations adopt Artificial Intelligence,
      automation and modern cloud technologies through practical,
      business-focused solutions that deliver measurable value.

    </p>

  </div>

</section>

<!-- ====================================================== -->

<section class="py-20">

  <div class="mx-auto max-w-5xl px-6">

    <div class="space-y-8 text-lg leading-9 text-slate-600">

      <p>

        We believe AI should solve real business challenges—not become
        another technology project.

      </p>

      <p>

        Our consultants work with business leaders to identify
        opportunities where Artificial Intelligence, automation and cloud
        technologies can improve productivity, streamline operations and
        support sustainable growth.

      </p>

      <p>

        Every engagement begins with understanding your business,
        existing processes and strategic objectives before recommending
        the right technology approach.

      </p>

      <p>

        We focus on practical outcomes, responsible AI adoption and
        solutions that integrate with the technologies organisations
        already use.

      </p>

    </div>

  </div>

</section>

<!-- ====================================================== -->

<section class="bg-slate-50 py-20">

  <div class="mx-auto max-w-6xl px-6">

    <div class="text-center">

      <h2 class="text-4xl font-bold text-slate-900">

        What We Deliver

      </h2>

    </div>

    <div class="mt-14 grid gap-8 md:grid-cols-2 lg:grid-cols-4">

      <div class="rounded-2xl border border-slate-200 bg-white p-8">

        <h3 class="font-semibold text-slate-900">
          AI Strategy
        </h3>

        <p class="mt-4 text-slate-600">
          Practical roadmaps aligned with business priorities.
        </p>

      </div>

      <div class="rounded-2xl border border-slate-200 bg-white p-8">

        <h3 class="font-semibold text-slate-900">
          Business Automation
        </h3>

        <p class="mt-4 text-slate-600">
          Reduce manual work through intelligent automation.
        </p>

      </div>

      <div class="rounded-2xl border border-slate-200 bg-white p-8">

        <h3 class="font-semibold text-slate-900">
          Responsible AI
        </h3>

        <p class="mt-4 text-slate-600">
          Security, governance and compliance built into every solution.
        </p>

      </div>

      <div class="rounded-2xl border border-slate-200 bg-white p-8">

        <h3 class="font-semibold text-slate-900">
          Continuous Improvement
        </h3>

        <p class="mt-4 text-slate-600">
          Helping organisations maximise long-term value from AI.
        </p>

      </div>

    </div>

  </div>

</section>

<!-- ====================================================== -->

<BusinessContact />

</MainLayout>
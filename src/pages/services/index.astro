---
import MainLayout from "../../layouts/MainLayout.astro";
import ServiceCard from "../../components/ServiceCard.astro";
import { services } from "../../data/services";
---

<MainLayout
  title="Enterprise AI Services | Ragan Dynamics"
  description="Enterprise AI consulting, AI strategy, AI agents, Microsoft Copilot, automation and AI governance for organisations in Singapore.">

  <!-- Hero -->
  <section class="relative overflow-hidden bg-slate-950">

    <div class="absolute inset-0 bg-gradient-to-r from-blue-700/20 via-indigo-600/20 to-purple-700/20"></div>

    <div class="relative mx-auto max-w-7xl px-6 py-28">

      <span class="rounded-full border border-blue-500/30 bg-blue-500/10 px-4 py-2 text-sm font-semibold text-blue-300">
        Enterprise AI Consultancy
      </span>

      <h1 class="mt-8 max-w-4xl text-5xl font-extrabold leading-tight text-white lg:text-7xl">
        AI Services That Deliver
        <span class="bg-gradient-to-r from-blue-400 to-purple-400 bg-clip-text text-transparent">
          Measurable Business Outcomes
        </span>
      </h1>

      <p class="mt-8 max-w-3xl text-xl leading-9 text-slate-300">
        We help organisations define an AI strategy, build intelligent
        assistants, automate business processes and deploy enterprise AI
        securely with measurable return on investment.
      </p>

      <div class="mt-10 flex flex-wrap gap-4">

        <a
          href="/contact"
          class="rounded-xl bg-blue-600 px-8 py-4 font-semibold text-white transition hover:bg-blue-700">
          Book Free Consultation
        </a>

        <a
          href="#services"
          class="rounded-xl border border-slate-700 px-8 py-4 font-semibold text-white hover:bg-slate-900">
          Explore Services
        </a>

      </div>

    </div>

  </section>

  <!-- ROI -->
  <section class="bg-white">

    <div class="mx-auto grid max-w-7xl gap-8 px-6 py-20 md:grid-cols-2 xl:grid-cols-4">

      <div class="rounded-3xl border p-8 text-center shadow-sm">
        <div class="text-5xl font-black text-blue-600">40%</div>
        <p class="mt-3 text-slate-600">Higher Productivity</p>
      </div>

      <div class="rounded-3xl border p-8 text-center shadow-sm">
        <div class="text-5xl font-black text-indigo-600">60%</div>
        <p class="mt-3 text-slate-600">Reduced Manual Work</p>
      </div>

      <div class="rounded-3xl border p-8 text-center shadow-sm">
        <div class="text-5xl font-black text-purple-600">3×</div>
        <p class="mt-3 text-slate-600">Faster Decision Making</p>
      </div>

      <div class="rounded-3xl border p-8 text-center shadow-sm">
        <div class="text-5xl font-black text-emerald-600">24×7</div>
        <p class="mt-3 text-slate-600">AI-Powered Operations</p>
      </div>

    </div>

  </section>

  <!-- Services -->
  <section
    id="services"
    class="bg-slate-50">

    <div class="mx-auto max-w-7xl px-6 py-24">

      <div class="mx-auto max-w-3xl text-center">

        <span class="font-semibold uppercase tracking-widest text-blue-600">
          Our Services
        </span>

        <h2 class="mt-6 text-5xl font-bold text-slate-900">
          End-to-End Enterprise AI Services
        </h2>

        <p class="mt-6 text-lg leading-8 text-slate-600">
          From AI strategy through implementation and governance,
          we help businesses transform operations with practical,
          secure and scalable AI solutions.
        </p>

      </div>

      <div class="mt-20 grid gap-8 lg:grid-cols-2">

        {
          services.map(service => (
            <ServiceCard service={service} />
          ))
        }

      </div>

    </div>

  </section>

  <!-- Why Us -->
  <section class="bg-white">

    <div class="mx-auto max-w-7xl px-6 py-24">

      <div class="grid gap-20 lg:grid-cols-2">

        <div>

          <h2 class="text-5xl font-bold text-slate-900">
            Why Ragan Dynamics?
          </h2>

          <p class="mt-6 text-lg leading-8 text-slate-600">
            We combine enterprise architecture, cloud expertise,
            automation and generative AI to create practical solutions
            that deliver measurable business value.
          </p>

        </div>

        <div class="space-y-6">

          <div class="rounded-2xl border p-6">
            <h3 class="font-semibold">Enterprise AI Strategy</h3>
            <p class="mt-2 text-slate-600">
              Align AI investments with business objectives.
            </p>
          </div>

          <div class="rounded-2xl border p-6">
            <h3 class="font-semibold">Cloud & AI Architecture</h3>
            <p class="mt-2 text-slate-600">
              Secure, scalable architectures for enterprise AI.
            </p>
          </div>

          <div class="rounded-2xl border p-6">
            <h3 class="font-semibold">Responsible AI</h3>
            <p class="mt-2 text-slate-600">
              Governance, security and compliance built in from day one.
            </p>
          </div>

        </div>

      </div>

    </div>

  </section>

  <!-- CTA -->
  <section class="bg-gradient-to-r from-blue-700 to-indigo-700">

    <div class="mx-auto max-w-5xl px-6 py-24 text-center">

      <h2 class="text-5xl font-bold text-white">
        Ready to Accelerate Your AI Journey?
      </h2>

      <p class="mt-6 text-xl text-blue-100">
        Discover where AI can create the greatest impact for your
        organisation with a tailored strategy session.
      </p>

      <div class="mt-10">

        <a
          href="/contact"
          class="rounded-xl bg-white px-8 py-4 font-semibold text-blue-700 shadow-lg transition hover:bg-slate-100">
          Book Your Free AI Consultation
        </a>

      </div>

    </div>

  </section>

</MainLayout>
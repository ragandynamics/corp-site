---
import MainLayout from "../../layouts/MainLayout.astro";
import ProductCard from "../../components/ProductCard.astro";
import { products } from "../../data/products";
---

<MainLayout
  title="Enterprise AI Products | Ragan Dynamics"
  description="Production-ready AI products that accelerate digital transformation for enterprises and SMEs in Singapore.">

  <!-- Hero -->
  <section class="relative overflow-hidden bg-slate-950">

    <div class="absolute inset-0 bg-gradient-to-br from-blue-700/20 via-indigo-600/20 to-purple-700/20"></div>

    <div class="relative mx-auto max-w-7xl px-6 py-28">

      <span
        class="rounded-full border border-blue-500/30 bg-blue-500/10 px-4 py-2 text-sm font-semibold text-blue-300">
        AI Products
      </span>

      <h1 class="mt-8 max-w-5xl text-5xl font-extrabold leading-tight text-white lg:text-7xl">
        Ready-to-Deploy
        <span class="bg-gradient-to-r from-blue-400 to-purple-400 bg-clip-text text-transparent">
          Enterprise AI Products
        </span>
      </h1>

      <p class="mt-8 max-w-3xl text-xl leading-9 text-slate-300">
        Accelerate innovation with proven AI solutions for HR, Sales, Customer
        Service, Knowledge Management, Document Intelligence and more—without
        starting from scratch.
      </p>

      <div class="mt-10 flex flex-wrap gap-4">
        <a
          href="/contact"
          class="rounded-xl bg-blue-600 px-8 py-4 font-semibold text-white transition hover:bg-blue-700">
          Request a Demo
        </a>

        <a
          href="#catalogue"
          class="rounded-xl border border-slate-700 px-8 py-4 font-semibold text-white hover:bg-slate-900">
          Explore Products
        </a>
      </div>

    </div>

  </section>

  <!-- Product Benefits -->
  <section class="bg-white">

    <div class="mx-auto grid max-w-7xl gap-8 px-6 py-20 md:grid-cols-2 xl:grid-cols-4">

      <div class="rounded-3xl border p-8 text-center shadow-sm">
        <div class="text-5xl font-black text-blue-600">80%</div>
        <p class="mt-3 text-slate-600">Faster Deployment</p>
      </div>

      <div class="rounded-3xl border p-8 text-center shadow-sm">
        <div class="text-5xl font-black text-indigo-600">60%</div>
        <p class="mt-3 text-slate-600">Lower Development Costs</p>
      </div>

      <div class="rounded-3xl border p-8 text-center shadow-sm">
        <div class="text-5xl font-black text-purple-600">24×7</div>
        <p class="mt-3 text-slate-600">AI Availability</p>
      </div>

      <div class="rounded-3xl border p-8 text-center shadow-sm">
        <div class="text-5xl font-black text-emerald-600">ROI</div>
        <p class="mt-3 text-slate-600">Business Value from Day One</p>
      </div>

    </div>

  </section>

  <!-- Catalogue -->
  <section id="catalogue" class="bg-slate-50">

    <div class="mx-auto max-w-7xl px-6 py-24">

      <div class="mx-auto max-w-3xl text-center">

        <span class="font-semibold uppercase tracking-widest text-blue-600">
          Product Catalogue
        </span>

        <h2 class="mt-6 text-5xl font-bold text-slate-900">
          AI Solutions Built for Business
        </h2>

        <p class="mt-6 text-lg leading-8 text-slate-600">
          Every solution is designed to integrate with your existing business
          systems, accelerate time-to-value and support secure enterprise AI
          adoption.
        </p>

      </div>

      <div class="mt-20 grid gap-8 md:grid-cols-2 xl:grid-cols-3">

        {
          products.map((product) => (
            <ProductCard product={product} />
          ))
        }

      </div>

    </div>

  </section>

  <!-- Services vs Products -->
  <section class="bg-white">

    <div class="mx-auto max-w-7xl px-6 py-24">

      <div class="text-center">

        <h2 class="text-4xl font-bold text-slate-900">
          Consulting Services or AI Products?
        </h2>

        <p class="mt-4 text-lg text-slate-600">
          Choose the engagement model that best fits your organisation.
        </p>

      </div>

      <div class="mt-16 grid gap-8 lg:grid-cols-2">

        <div class="rounded-3xl border bg-slate-50 p-10">

          <h3 class="text-2xl font-bold text-slate-900">
            AI Consulting Services
          </h3>

          <ul class="mt-8 space-y-4 text-slate-700">
            <li>✓ AI strategy and roadmap</li>
            <li>✓ Custom solution design</li>
            <li>✓ Change management</li>
            <li>✓ Enterprise architecture</li>
            <li>✓ Long-term transformation programmes</li>
          </ul>

          <a
            href="/services"
            class="mt-10 inline-flex rounded-xl bg-blue-600 px-6 py-3 font-semibold text-white">
            Explore Services
          </a>

        </div>

        <div class="rounded-3xl border border-blue-200 bg-blue-50 p-10">

          <h3 class="text-2xl font-bold text-slate-900">
            AI Products
          </h3>

          <ul class="mt-8 space-y-4 text-slate-700">
            <li>✓ Faster implementation</li>
            <li>✓ Lower development costs</li>
            <li>✓ Proven architecture</li>
            <li>✓ Enterprise ready</li>
            <li>✓ Rapid deployment</li>
          </ul>

          <a
            href="/contact"
            class="mt-10 inline-flex rounded-xl bg-gradient-to-r from-blue-600 to-purple-600 px-6 py-3 font-semibold text-white">
            Book Product Demo
          </a>

        </div>

      </div>

    </div>

  </section>

  <!-- CTA -->
  <section class="bg-gradient-to-r from-blue-700 via-indigo-700 to-purple-700">

    <div class="mx-auto max-w-5xl px-6 py-24 text-center">

      <h2 class="text-5xl font-bold text-white">
        Accelerate Your AI Transformation
      </h2>

      <p class="mt-6 text-xl text-blue-100">
        Whether you're looking for strategic consulting or ready-made AI
        products, our team can help you identify the fastest path to measurable
        business outcomes.
      </p>

      <div class="mt-10 flex flex-wrap justify-center gap-4">

        <a
          href="/contact"
          class="rounded-xl bg-white px-8 py-4 font-semibold text-blue-700 shadow-lg transition hover:bg-slate-100">
          Schedule a Consultation
        </a>

        <a
          href="/services"
          class="rounded-xl border border-white/30 px-8 py-4 font-semibold text-white hover:bg-white/10">
          View AI Services
        </a>

      </div>

    </div>

  </section>

</MainLayout>
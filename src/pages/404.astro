---
import MainLayout from "../layouts/MainLayout.astro";
---

<MainLayout
  title="Page Not Found | Ragan Dynamics"
  description="The page you are looking for could not be found."
>

<section class="bg-slate-50 py-24">

  <div class="mx-auto max-w-3xl px-6 text-center">

    <div class="mb-6 text-8xl font-black text-blue-600">
      404
    </div>

    <h1 class="text-4xl font-bold text-slate-900">
      We couldn't find that page
    </h1>

    <p class="mt-6 text-lg leading-8 text-slate-600">
      The page may have been moved, renamed or no longer exists.
    </p>

    <div class="mt-12 flex flex-wrap justify-center gap-4">

      <a
        href="/"
        class="rounded-xl bg-blue-600 px-8 py-4 font-semibold text-white hover:bg-blue-700"
      >
        Home
      </a>

      <a
        href="/assessment"
        class="rounded-xl border border-blue-600 px-8 py-4 font-semibold text-blue-600 hover:bg-blue-50"
      >
        Free AI Transformation & ROI Assessment
      </a>

      <a
        href="/services"
        class="rounded-xl border border-slate-300 px-8 py-4 font-semibold text-slate-700 hover:bg-slate-100"
      >
        Our Services
      </a>

      <a
        href="/contact"
        class="rounded-xl border border-slate-300 px-8 py-4 font-semibold text-slate-700 hover:bg-slate-100"
      >
        Contact Us
      </a>

    </div>

  </div>

</section>

</MainLayout>
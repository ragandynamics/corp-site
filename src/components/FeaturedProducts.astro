---
const products = [

{
name:"AI Startup Studio",
icon:"🚀",

tagline:"Launch AI SaaS Faster",

description:
"Production-ready platform for building enterprise AI applications with authentication, billing, AI integration and Cloudflare deployment.",

link:"/products#startup-studio",

badge:"Platform"

},

{
name:"Enterprise Knowledge Assistant",

icon:"🧠",

tagline:"Private Enterprise ChatGPT",

description:
"Secure AI assistant powered by your organisation's documents, policies and knowledge using Retrieval-Augmented Generation (RAG).",

link:"/products#knowledge",

badge:"Enterprise"

},

{
name:"Resume AI",

icon:"📄",

tagline:"AI Resume Optimisation",

description:
"Analyse resumes, match jobs, improve ATS scores and provide personalised recommendations using Generative AI.",

link:"/products#resume",

badge:"HR"

},

{
name:"Document Intelligence",

icon:"📑",

tagline:"Process Documents Automatically",

description:
"Extract data from invoices, contracts and forms with AI-powered document understanding and workflow automation.",

link:"/products#documents",

badge:"Automation"

},

{
name:"AI Sales Copilot",

icon:"📈",

tagline:"Empower Sales Teams",

description:
"Generate proposals, qualify leads, summarise meetings and provide CRM insights to accelerate sales performance.",

link:"/products#sales",

badge:"Sales"

},

{
name:"AI Customer Support",

icon:"💬",

tagline:"24×7 Customer Service",

description:
"Deliver intelligent customer support across web, Microsoft Teams, WhatsApp and mobile applications.",

link:"/products#support",

badge:"CX"

}

];
---

<section class="bg-white">

<div class="mx-auto max-w-7xl px-6 py-28">

<div class="mx-auto max-w-3xl text-center">

<span
class="font-semibold uppercase tracking-[0.3em] text-indigo-600">

AI PRODUCTS

</span>

<h2
class="mt-6 text-5xl font-black text-slate-900">

Accelerate Innovation

Without Starting From Scratch

</h2>

<p
class="mt-8 text-xl leading-9 text-slate-600">

Deploy proven enterprise AI solutions in weeks instead of months.
Reduce implementation costs, minimise project risk and accelerate
your return on investment.

</p>

</div>

<div
class="mt-20 grid gap-8 md:grid-cols-2 xl:grid-cols-3">

{
products.map(product=>(

<article
class="group flex flex-col rounded-3xl border border-slate-200 bg-white p-8 shadow-sm transition-all duration-300 hover:-translate-y-2 hover:border-indigo-500 hover:shadow-2xl">

<div
class="flex items-center justify-between">

<div
class="flex h-16 w-16 items-center justify-center rounded-2xl bg-gradient-to-r from-indigo-600 to-purple-600 text-3xl text-white">

{product.icon}

</div>

<span
class="rounded-full bg-indigo-100 px-3 py-1 text-xs font-bold uppercase tracking-wider text-indigo-700">

{product.badge}

</span>

</div>

<h3
class="mt-8 text-2xl font-bold text-slate-900">

{product.name}

</h3>

<p
class="mt-2 font-semibold text-indigo-600">

{product.tagline}

</p>

<p
class="mt-6 flex-grow leading-8 text-slate-600">

{product.description}

</p>

<a
href={product.link}
class="mt-8 inline-flex items-center font-semibold text-indigo-600">

View Product

<span
class="ml-2 transition group-hover:translate-x-2">

→

</span>

</a>

</article>

))
}

</div>

<div
class="mt-20 rounded-3xl bg-gradient-to-r from-slate-900 via-indigo-900 to-slate-900 p-12 text-center text-white">

<h3
class="text-4xl font-black">

Looking for a Custom AI Solution?

</h3>

<p
class="mx-auto mt-6 max-w-3xl text-xl leading-9 text-slate-300">

Need something tailored to your organisation?
Our consultants can customise existing products or build
enterprise AI applications aligned with your business objectives.

</p>

<div
class="mt-10 flex flex-wrap justify-center gap-4">

<a
href="/products"
class="rounded-xl bg-white px-8 py-4 font-semibold text-slate-900">

Browse Products

</a>

<a
href="/contact"
class="rounded-xl border border-white/20 px-8 py-4 font-semibold text-white hover:bg-white/10">

Request a Demo

</a>

</div>

</div>

</div>

</section>
---
export interface Props{

eyebrow:string;

title:string;

description?:string;

center?:boolean;

}

const{

eyebrow,
title,
description,
center=true

}=Astro.props;
---

<div
class:list={[

"max-w-4xl",

center && "mx-auto text-center"

]}>

<span
class="font-bold uppercase tracking-[0.35em] text-blue-600">

{eyebrow}

</span>

<h2
class="mt-6 text-5xl font-black text-slate-900 lg:text-6xl">

{title}

</h2>

{

description && (

<p
class="mt-8 text-xl leading-9 text-slate-600">

{description}

</p>

)

}

</div>
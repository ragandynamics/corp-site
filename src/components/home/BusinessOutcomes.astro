---
import Container from "../ui/Container.astro";

const outcomes = [

{
title:"Reduce Operating Costs",
value:"Up to 30%",
description:"Automate repetitive work and optimise operational efficiency."
},

{
title:"Increase Productivity",
value:"2x Faster",
description:"AI assistants help employees complete work more efficiently."
},

{
title:"Improve Customer Experience",
value:"24/7",
description:"AI-powered chatbots provide instant responses around the clock."
},

{
title:"Faster Decision Making",
value:"Real-Time",
description:"AI analytics provide insights for informed business decisions."
},

{
title:"Scale Without Hiring",
value:"Smarter Growth",
description:"Handle more work without proportionally increasing headcount."
},

{
title:"Future-Ready Business",
value:"AI Enabled",
description:"Build a competitive advantage with modern AI capabilities."
}

];
---

<section class="section-padding bg-white">

  <Container>

    <div class="text-center">

      <span class="inline-flex rounded-full bg-blue-100 px-4 py-2 text-sm font-semibold text-blue-700">

        Business Outcomes

      </span>

      <h2 class="mt-6 text-4xl font-black text-slate-900">

        Measurable Business Value, Not Just Technology

      </h2>

      <p class="mx-auto mt-6 max-w-3xl text-lg text-slate-600">

        Every AI initiative is designed to reduce costs, improve
        productivity and deliver measurable business outcomes.

      </p>

    </div>

    <div class="mt-16 grid gap-8 md:grid-cols-2 xl:grid-cols-3">

      {
        outcomes.map((item) => (

          <div class="rounded-3xl border border-slate-200 p-8 transition hover:-translate-y-2 hover:shadow-xl">

            <div class="text-4xl font-black text-blue-600">

              {item.value}

            </div>

            <h3 class="mt-5 text-2xl font-bold text-slate-900">

              {item.title}

            </h3>

            <p class="mt-4 leading-8 text-slate-600">

              {item.description}

            </p>

          </div>

        ))
      }

    </div>

    <div class="mt-16 rounded-3xl bg-blue-50 p-10 text-center">

      <h3 class="text-3xl font-black text-slate-900">

        Start Small. Scale with Confidence.

      </h3>

      <p class="mx-auto mt-6 max-w-3xl text-lg text-slate-600">

        Our phased AI adoption approach helps Singapore SMEs realise
        business value quickly while managing costs and implementation risk.

      </p>

      <a

        href="/contact"

        data-analytics="business-outcomes-cta"

        class="mt-8 inline-flex rounded-xl bg-blue-600 px-8 py-4 font-bold text-white transition hover:bg-blue-700"

      >

        Talk to an AI Consultant

      </a>

    </div>

  </Container>

</section>
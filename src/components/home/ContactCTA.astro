---
import Container from "../ui/Container.astro";
---

<section class="section-padding bg-blue-700">

  <Container>

    <div class="rounded-3xl bg-gradient-to-r from-blue-700 to-blue-900 p-12 text-center text-white">

      <h2 class="text-4xl font-black">
        Ready to Start Your AI Journey?
      </h2>

      <p class="mx-auto mt-6 max-w-3xl text-lg text-blue-100">
        Speak with our AI consultants to discover practical and
        cost-effective AI solutions for your organisation.
      </p>

      <div class="mt-10 flex flex-wrap justify-center gap-4">

        <a
          href="/contact"
          data-analytics="contact-cta"
          class="rounded-xl bg-white px-8 py-4 font-bold text-blue-700 transition hover:bg-slate-100"
        >
          Book a Free Consultation
        </a>

        <a
          href="/services"
          class="rounded-xl border border-white px-8 py-4 font-bold text-white transition hover:bg-white hover:text-blue-700"
        >
          Explore Services
        </a>

      </div>

    </div>

  </Container>

</section>
---
import Container from "../ui/Container.astro";
---

<section class="section-padding bg-white">

  <Container>

    <div class="grid gap-16 items-center lg:grid-cols-2">

      <div>

        <span class="inline-flex rounded-full bg-blue-100 px-4 py-2 text-sm font-semibold text-blue-700">
          About Ragan Dynamics
        </span>

        <h2 class="mt-6 text-4xl font-black text-slate-900">
          Helping organisations adopt AI with confidence
        </h2>

        <p class="mt-6 text-lg leading-8 text-slate-600">
          Ragan Dynamics partners with organisations to identify,
          design and implement practical Artificial Intelligence
          solutions that deliver measurable business value.
        </p>

        <p class="mt-6 leading-8 text-slate-600">
          Our approach combines business consulting, cloud architecture,
          automation and modern AI technologies to solve real business
          problems—not just deploy technology.
        </p>

        <div class="mt-10 grid gap-6 sm:grid-cols-2">

          <div class="rounded-2xl border border-slate-200 p-6">
            <h3 class="text-3xl font-black text-blue-600">10+</h3>
            <p class="mt-2 font-semibold text-slate-900">
              Years Enterprise Experience
            </p>
          </div>

          <div class="rounded-2xl border border-slate-200 p-6">
            <h3 class="text-3xl font-black text-blue-600">ROI</h3>
            <p class="mt-2 font-semibold text-slate-900">
              Business Outcome Driven
            </p>
          </div>

        </div>

      </div>

      <div class="rounded-3xl bg-slate-900 p-10 text-white shadow-2xl">

        <h3 class="text-3xl font-bold">
          Why organisations choose us
        </h3>

        <ul class="mt-8 space-y-5">

          <li>✓ Practical AI strategies aligned to business goals</li>

          <li>✓ Cost-effective cloud and AI solution design</li>

          <li>✓ Secure enterprise AI architecture</li>

          <li>✓ Automation that improves productivity</li>

          <li>✓ Microsoft, Azure and Cloud expertise</li>

          <li>✓ Measurable ROI and business outcomes</li>

        </ul>

      </div>

    </div>

  </Container>

</section>
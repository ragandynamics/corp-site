---
import Container from "../ui/Container.astro";
import ServiceCard from "../ServiceCard.astro";
import { services } from "../../data/services";
---

<section id="services" class="section-padding bg-slate-50">

  <Container>

    <div class="text-center">

      <span class="inline-flex rounded-full bg-blue-100 px-4 py-2 text-sm font-semibold text-blue-700">
        AI Services
      </span>

      <h2 class="mt-6 text-4xl font-black text-slate-900">
        Enterprise AI Services
      </h2>

      <p class="mx-auto mt-6 max-w-3xl text-lg text-slate-600">
        Practical AI consulting, automation and cloud solutions that
        deliver measurable business outcomes.
      </p>

    </div>

    <div class="mt-16 grid gap-8 md:grid-cols-2 xl:grid-cols-3">

      {
        services.map((service) => (
          <ServiceCard service={service} />
        ))
      }

    </div>

  </Container>

</section>
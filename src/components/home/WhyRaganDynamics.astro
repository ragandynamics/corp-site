---
import Container from "../ui/Container.astro";

import SectionTitle from "../ui/SectionTitle.astro";

import Card from "../ui/Card.astro";

import Badge from "../ui/Badge.astro";


const reasons = [

{
icon:"🎯",

title:"Business-First AI Strategy",

description:
"We focus on business outcomes, not just technology. Every AI initiative starts by identifying opportunities that improve productivity, reduce costs and create measurable business value.",

impact:
"ROI-driven AI approach"

},


{
icon:"💡",

title:"Cost-Effective AI Solutioning",

description:
"We design AI solutions based on your business goals, budget and expected ROI. Our approach balances cloud AI, automation and modern AI platforms to deliver maximum value without unnecessary complexity or cost.",

impact:
"Maximum value with optimised investment"

},


{
icon:"🚀",

title:"Practical AI Implementation",

description:
"We help organisations move from AI ideas to real business solutions through structured planning, rapid prototyping and scalable implementation.",

impact:
"Faster AI adoption"

},


{
icon:"🔐",

title:"Secure & Responsible AI",

description:
"We build AI solutions with security, privacy, governance and responsible AI practices considered from the beginning.",

impact:
"Enterprise-ready AI"

},


{
icon:"☁️",

title:"Cloud & AI Expertise",

description:
"We leverage leading cloud platforms and AI technologies to build flexible, scalable and cost-conscious AI architectures.",

impact:
"Future-ready solutions"

},


{
icon:"🤝",

title:"Long-Term AI Partner",

description:
"We work together with your teams to continuously improve, optimise and expand AI capabilities as your business evolves.",

impact:
"Continuous AI transformation"

}

];

---

<section

class="
section-padding
bg-slate-50
"

>


<Container>


<SectionTitle

eyebrow="Why Ragan Dynamics"

title="Why Businesses Choose Ragan Dynamics For AI Transformation"

description="
We combine AI expertise, business understanding and
cost-effective solutioning to help organisations adopt
practical AI solutions that deliver measurable ROI.
"

/>



<div

class="
mt-20
grid
gap-8
md:grid-cols-2
lg:grid-cols-3
"

>


{

reasons.map((reason)=>(


<Card>


<div

class="
flex
h-14
w-14
items-center
justify-center
rounded-2xl
bg-blue-100
text-3xl
"

>

{reason.icon}

</div>



<h3

class="
mt-8
text-2xl
font-black
text-slate-900
"

>

{reason.title}

</h3>



<p

class="
mt-5
leading-8
text-slate-600
"

>

{reason.description}

</p>



<div

class="
mt-8
"

>

<Badge color="green">

{reason.impact}

</Badge>


</div>



</Card>


))

}


</div>


</Container>


</section>
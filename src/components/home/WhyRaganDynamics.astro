---
import Container from "../ui/Container.astro";

const usp = [
  {
    title: "Business-First AI Strategy",
    description:
      "Every AI initiative is aligned with measurable business outcomes."
  },
  {
    title: "Cost-Effective Solutions",
    description:
      "Cloud-native architectures that minimise implementation and operational costs."
  },
  {
    title: "Enterprise Security",
    description:
      "AI solutions designed with governance, security and compliance in mind."
  },
  {
    title: "Rapid Delivery",
    description:
      "Accelerators and reusable components shorten implementation time."
  },
  {
    title: "Vendor-Neutral Expertise",
    description:
      "Experience across Microsoft, Azure, AWS, Google Cloud and Cloudflare."
  },
  {
    title: "Measurable Business Value",
    description:
      "Focus on productivity, automation, cost savings and ROI."
  }
];
---

<section class="section-padding bg-slate-900 text-white">

  <Container>

    <div class="text-center">

      <span class="inline-flex rounded-full bg-blue-600 px-4 py-2 text-sm font-semibold">
        Why Ragan Dynamics
      </span>

      <h2 class="mt-6 text-4xl font-black">
        Your Trusted AI Transformation Partner
      </h2>

      <p class="mx-auto mt-6 max-w-3xl text-lg text-slate-300">
        We help organisations adopt Artificial Intelligence with practical,
        secure and cost-effective solutions that deliver measurable business value.
      </p>

    </div>

    <div class="mt-16 grid gap-8 md:grid-cols-2 lg:grid-cols-3">

      {
        usp.map((item) => (

          <div class="rounded-2xl bg-slate-800 p-8">

            <h3 class="text-xl font-bold text-white">
              {item.title}
            </h3>

            <p class="mt-4 text-slate-300">
              {item.description}
            </p>

          </div>

        ))
      }

    </div>

  </Container>

</section>
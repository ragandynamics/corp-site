top-20
h-96
w-96
rounded-full
bg-blue-500/20
blur-3xl
">
</div>


<div
class="
absolute
left-20
bottom-0
h-80
w-80
rounded-full
bg-indigo-500/20
blur-3xl
">
</div>



<Container>


<div
class="
relative
grid
min-h-[750px]
items-center
gap-16
lg:grid-cols-2
">


<!-- Left Content -->

<div>


<Badge color="blue">

Enterprise AI Transformation

</Badge>



<h1
class="
mt-8
text-5xl
font-black
leading-tight
tracking-tight
lg:text-7xl

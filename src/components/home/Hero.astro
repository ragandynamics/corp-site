---
import Container from "../ui/Container.astro";
import { site } from "../../config/site";

const { company } = site;
---

<section class="relative overflow-hidden bg-gradient-to-br from-slate-950 via-slate-900 to-blue-900">

  <div class="absolute inset-0 bg-[radial-gradient(circle_at_top_right,#2563eb22,transparent_40%)]"></div>

  <Container>

    <div class="relative grid items-center gap-16 py-24 lg:grid-cols-2">

      <!-- ================================================= -->
      <!-- Left -->
      <!-- ================================================= -->

      <div>

        <span
          class="inline-flex items-center rounded-full bg-blue-600/20 px-4 py-2 text-sm font-semibold text-blue-300"
        >
          🇸🇬 {company.tagline}
        </span>

        <h1
          class="mt-8 text-5xl font-black leading-tight text-white lg:text-6xl"
        >

          Practical AI Solutions

          <span class="block text-blue-400">
            That Help SMEs
          </span>

          <span class="block text-blue-300">
            Work Smarter and Grow Faster
          </span>

        </h1>

        <p class="mt-8 text-xl leading-9 text-slate-300">

          We help Singapore businesses identify practical opportunities
          to adopt Artificial Intelligence, automate repetitive work,
          improve productivity and make better business decisions with
          secure, scalable and cost-effective solutions.

        </p>

        <div class="mt-10 flex flex-wrap gap-4">

          <a
            href="/contact"
            data-analytics="hero-consultation"
            class="rounded-xl bg-blue-600 px-8 py-4 text-lg font-bold text-white transition hover:bg-blue-700"
          >
            Book an AI Consultation
          </a>

          <a
            href="/services"
            class="rounded-xl border border-white px-8 py-4 text-lg font-semibold text-white transition hover:bg-white hover:text-slate-900"
          >
            Explore Our Services
          </a>

        </div>

        <div class="mt-12 grid grid-cols-2 gap-6 md:grid-cols-4">

          <div>

            <div class="text-3xl font-black text-blue-400">
              AI
            </div>

            <p class="mt-2 text-sm text-slate-300">
              Strategy
            </p>

          </div>

          <div>

            <div class="text-3xl font-black text-blue-400">
              AI
            </div>

            <p class="mt-2 text-sm text-slate-300">
              Automation
            </p>

          </div>

          <div>

            <div class="text-3xl font-black text-blue-400">
              Cloud
            </div>

            <p class="mt-2 text-sm text-slate-300">
              Solutions
            </p>

          </div>

          <div>

            <div class="text-3xl font-black text-blue-400">
              ROI
            </div>

            <p class="mt-2 text-sm text-slate-300">
              Business Focused
            </p>

          </div>

        </div>

      </div>

      <!-- ================================================= -->
      <!-- Right -->
      <!-- ================================================= -->

      <div>

        <div class="rounded-3xl bg-white p-8 shadow-2xl">

          <h2 class="text-3xl font-black text-slate-900">

            Your AI Journey Starts Here

          </h2>

          <div class="mt-8 space-y-5">

            <div class="rounded-xl bg-slate-50 p-5">

              <h3 class="font-bold text-slate-900">

                Discover Opportunities

              </h3>

              <p class="mt-2 text-slate-600">

                Identify practical AI use cases aligned with your business goals.

              </p>

            </div>

            <div class="rounded-xl bg-slate-50 p-5">

              <h3 class="font-bold text-slate-900">

                Build with Confidence

              </h3>

              <p class="mt-2 text-slate-600">

                Implement secure, scalable solutions that integrate with your existing systems.

              </p>

            </div>

            <div class="rounded-xl bg-slate-50 p-5">

              <h3 class="font-bold text-slate-900">

                Deliver Measurable Value

              </h3>

              <p class="mt-2 text-slate-600">

                Improve productivity, streamline operations and support long-term business growth.

              </p>

            </div>

          </div>

        </div>

      </div>

    </div>

  </Container>

</section>
---
import Container from "../ui/Container.astro";
---

<section class="relative overflow-hidden bg-gradient-to-br from-slate-950 via-slate-900 to-blue-900">

  <div class="absolute inset-0 bg-[radial-gradient(circle_at_top_right,#2563eb22,transparent_40%)]"></div>

  <Container>

    <div class="relative grid items-center gap-16 py-24 lg:grid-cols-2">

      <!-- Left -->

      <div>

        <span class="inline-flex items-center rounded-full bg-blue-600/20 px-4 py-2 text-sm font-semibold text-blue-300">

          🇸🇬 Trusted AI Partner for Singapore SMEs

        </span>

        <h1 class="mt-8 text-5xl font-black leading-tight text-white lg:text-6xl">

          Transform Your Business with
          <span class="text-blue-400">
            Practical AI
          </span>
          That Delivers
          <span class="text-blue-300">
            Measurable Results
          </span>

        </h1>

        <p class="mt-8 text-xl leading-9 text-slate-300">

          Reduce operating costs, automate repetitive work, improve
          employee productivity and accelerate business growth with
          secure, scalable and cost-effective AI solutions designed
          specifically for Singapore SMEs.

        </p>

        <div class="mt-10 flex flex-wrap gap-4">

          <a

            href="/contact"

            data-analytics="hero-discovery"

            class="rounded-xl bg-blue-600 px-8 py-4 text-lg font-bold text-white transition hover:bg-blue-700"

          >

            Book a Free AI Discovery Session

          </a>

          <a

            href="#services"

            class="rounded-xl border border-white px-8 py-4 text-lg font-semibold text-white transition hover:bg-white hover:text-slate-900"

          >

            Explore AI Solutions

          </a>

        </div>

        <div class="mt-12 grid grid-cols-2 gap-6 md:grid-cols-4">

          <div>

            <div class="text-3xl font-black text-blue-400">
              30%
            </div>

            <p class="mt-2 text-sm text-slate-300">
              Lower Operating Costs
            </p>

          </div>

          <div>

            <div class="text-3xl font-black text-blue-400">
              80%
            </div>

            <p class="mt-2 text-sm text-slate-300">
              Less Manual Work
            </p>

          </div>

          <div>

            <div class="text-3xl font-black text-blue-400">
              24/7
            </div>

            <p class="mt-2 text-sm text-slate-300">
              AI Customer Support
            </p>

          </div>

          <div>

            <div class="text-3xl font-black text-blue-400">
              ROI
            </div>

            <p class="mt-2 text-sm text-slate-300">
              Business Focused
            </p>

          </div>

        </div>

      </div>

      <!-- Right -->

      <div>

        <div class="rounded-3xl bg-white p-8 shadow-2xl">

          <h2 class="text-3xl font-black text-slate-900">

            Why SMEs Choose AI

          </h2>

          <div class="mt-8 space-y-5">

            <div class="rounded-xl bg-slate-50 p-5">

              <h3 class="font-bold text-slate-900">

                Reduce Costs

              </h3>

              <p class="mt-2 text-slate-600">

                Eliminate repetitive manual work and optimise operations.

              </p>

            </div>

            <div class="rounded-xl bg-slate-50 p-5">

              <h3 class="font-bold text-slate-900">

                Increase Productivity

              </h3>

              <p class="mt-2 text-slate-600">

                Empower employees with AI assistants and automation.

              </p>

            </div>

            <div class="rounded-xl bg-slate-50 p-5">

              <h3 class="font-bold text-slate-900">

                Grow Revenue

              </h3>

              <p class="mt-2 text-slate-600">

                Deliver faster customer service and better business insights.

              </p>

            </div>

          </div>

        </div>

      </div>

    </div>

  </Container>

</section>
Ragan<span class="text-blue-600">Dynamics</span>

</a>

<nav class="hidden lg:flex gap-8">

{
menu.map(item=>(

<a
href={"/"+item.toLowerCase()}
class="hover:text-blue-600">

{item}

</a>

))
}

</nav>

<div class="flex gap-3">


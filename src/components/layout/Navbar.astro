---
import { site } from "../../config/site";

const { company, contact } = site;

const navigation = [
  {
    label: "Home",
    href: "/"
  },
  {
    label: "Services",
    href: "/services"
  },
  {
    label: "Industries",
    href: "/industries"
  },
  {
    label: "AI Transformation & ROI Assessment",
    href: "/assessment"
  },
  {
    label: "Insights",
    href: "/insights"
  },
  {
    label: "About",
    href: "/about"
  },
  {
    label: "Contact",
    href: "/contact"
  }
];

const pathname = Astro.url.pathname;
---

<header
  class="sticky top-0 z-50 border-b border-slate-200 bg-white/95 backdrop-blur"
>

  <div
    class="mx-auto flex h-20 max-w-7xl items-center justify-between px-6"
  >


    <!-- Logo -->

    <a
      href="/"
      class="flex items-center gap-3"
    >

      <div
        class="flex h-11 w-11 items-center justify-center rounded-xl bg-blue-600 text-lg font-bold text-white"
      >
        RD
      </div>


      <div>

        <div class="text-lg font-bold text-slate-900">

          {company.name}

        </div>


        <div class="text-xs text-slate-500">

          {company.tagline}

        </div>


      </div>


    </a>



    <!-- Desktop Navigation -->


    <nav
      class="hidden items-center gap-7 lg:flex"
    >

      {
        navigation.map((item) => (

          <a

            href={item.href}

            class:list={[

              "text-sm font-medium transition-colors",

              pathname === item.href

              ? "text-blue-600"

              : "text-slate-600 hover:text-blue-600"

            ]}

          >

            {item.label}

          </a>

        ))
      }


    </nav>



    <!-- Desktop CTA -->


    <div
      class="hidden items-center gap-4 lg:flex"
    >

      <a

        href={contact.enquiryForm}

        class="rounded-xl bg-blue-600 px-6 py-3 text-sm font-semibold text-white transition hover:bg-blue-700"

      >

        Book an AI Consultation

      </a>


    </div>



    <!-- Mobile Button -->


    <button

      id="mobile-menu-button"

      class="rounded-lg border border-slate-300 p-2 lg:hidden"

      aria-label="Open menu"

    >

      <svg

        xmlns="http://www.w3.org/2000/svg"

        class="h-6 w-6"

        fill="none"

        viewBox="0 0 24 24"

        stroke="currentColor"

      >

        <path

          stroke-linecap="round"

          stroke-linejoin="round"

          stroke-width="2"

          d="M4 6h16M4 12h16M4 18h16"

        />

      </svg>


    </button>


  </div>


</header>
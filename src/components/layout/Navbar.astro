---
import Logo from "./Logo.astro";
import Button from "../ui/Button.astro";

const navigation=[
{
title:"Services",
url:"/services"
},
{
title:"Products",
url:"/products"
},
{
title:"Industries",
url:"/industries"
},
{
title:"Insights",
url:"/insights"
},
{
title:"About",
url:"/about"
},
{
title:"Contact",
url:"/contact"
}
];
---

<header
class="sticky top-0 z-50 border-b border-slate-200/60 bg-white/90 backdrop-blur-xl">

<div
class="mx-auto flex max-w-7xl items-center justify-between px-6 py-4">

<Logo/>

<nav
class="hidden items-center gap-8 lg:flex">

{
navigation.map(item=>(

<a
href={item.url}
class="font-medium text-slate-600 transition hover:text-blue-600">

{item.title}

</a>

))
}

</nav>

<div
class="hidden items-center gap-4 lg:flex">

<Button
variant="outline"
href="/contact">

Talk to Us

</Button>

<Button
href="/contact">

Book Strategy Session

</Button>

</div>

<button
id="menuButton"
class="rounded-xl border p-3 lg:hidden">

☰

</button>

</div>

</header>
---
import { site } from "../../config/site";

const { company, contact } = site;
const year = new Date().getFullYear();
---

<footer class="border-t border-slate-200 bg-slate-950 text-slate-300">

  <div class="mx-auto max-w-7xl px-6 py-16">

    <div class="grid gap-12 lg:grid-cols-4">

      <!-- ================================================= -->
      <!-- Company -->
      <!-- ================================================= -->

      <div>

        <div class="flex items-center gap-3">

          <div
            class="flex h-10 w-10 items-center justify-center rounded-xl bg-blue-600 text-sm font-bold text-white"
          >
            RD
          </div>

          <div>

            <h3 class="text-xl font-bold text-white">
              {company.name}
            </h3>

            <p class="text-sm text-blue-300">
              {company.tagline}
            </p>

          </div>

        </div>

        <p class="mt-6 leading-7 text-slate-400">

          Helping Singapore SMEs adopt practical Artificial Intelligence,
          business automation and cloud technologies that improve
          productivity, reduce operational costs and accelerate digital
          transformation.

        </p>

      </div>

      <!-- ================================================= -->
      <!-- Services -->
      <!-- ================================================= -->

      <div>

        <h4 class="text-lg font-semibold text-white">
          Services
        </h4>

        <ul class="mt-6 space-y-3">

          <li>
            <a href="/services" class="hover:text-white">
              AI Strategy
            </a>
          </li>

          <li>
            <a href="/services" class="hover:text-white">
              AI Automation
            </a>
          </li>

          <li>
            <a href="/services" class="hover:text-white">
              Microsoft Copilot
            </a>
          </li>

          <li>
            <a href="/services" class="hover:text-white">
              AI Chatbots
            </a>
          </li>

          <li>
            <a href="/services" class="hover:text-white">
              Cloud Consulting
            </a>
          </li>

        </ul>

      </div>

      <!-- ================================================= -->
      <!-- Company -->
      <!-- ================================================= -->

      <div>

        <h4 class="text-lg font-semibold text-white">
          Company
        </h4>

        <ul class="mt-6 space-y-3">

          <li>
            <a href="/about" class="hover:text-white">
              About Us
            </a>
          </li>

          <li>
            <a href="/industries" class="hover:text-white">
              Industries
            </a>
          </li>

          <li>
            <a href="/insights" class="hover:text-white">
              Insights
            </a>
          </li>

          <li>
            <a href="/faq" class="hover:text-white">
              FAQ
            </a>
          </li>

          <li>
            <a href="/contact" class="hover:text-white">
              Contact
            </a>
          </li>

        </ul>

      </div>

      <!-- ================================================= -->
      <!-- Contact -->
      <!-- ================================================= -->

      <div>

        <h4 class="text-lg font-semibold text-white">
          Talk to Us
        </h4>

        <div class="mt-6 space-y-5">

          <div>

            <div class="text-sm uppercase tracking-wide text-slate-500">
              Office Phone
            </div>

            <a
              href={`tel:${contact.phone.tel}`}
              class="mt-1 inline-block hover:text-white"
            >
              {contact.phone.display}
            </a>

          </div>

          <div>

            <div class="text-sm uppercase tracking-wide text-slate-500">
              WhatsApp
            </div>

            <a
              href={contact.whatsapp.url}
              target="_blank"
              rel="noopener noreferrer"
              class="mt-1 inline-block hover:text-white"
            >
              {contact.whatsapp.display}
            </a>

          </div>

          <div>

            <div class="text-sm uppercase tracking-wide text-slate-500">
              Email
            </div>

            <a
              href={`mailto:${contact.email}`}
              class="mt-1 inline-block break-all hover:text-white"
            >
              {contact.email}
            </a>

          </div>

          <div class="pt-2">

            <a
              href={contact.enquiryForm}
              class="inline-flex rounded-xl bg-blue-600 px-6 py-3 font-semibold text-white transition hover:bg-blue-700"
            >
              Book an AI Consultation
            </a>

          </div>

        </div>

      </div>

    </div>

  </div>

  <!-- ================================================= -->
  <!-- Bottom -->
  <!-- ================================================= -->

  <div class="border-t border-slate-800">

    <div
      class="mx-auto flex max-w-7xl flex-col items-center justify-between gap-4 px-6 py-6 text-sm text-slate-500 md:flex-row"
    >

      <div>

        © {year} {company.name}. All rights reserved.

      </div>

      <div class="flex gap-6">

        <a href="/privacy" class="hover:text-white">
          Privacy Policy
        </a>

        <a href="/terms" class="hover:text-white">
          Terms of Use
        </a>

      </div>

    </div>

  </div>

</footer>
---
import Badge from "./ui/Badge.astro";


export interface Props {

product:any;

}


const {
product
}=Astro.props;

---

<div

class="
rounded-3xl
border
border-slate-200
bg-white
p-8
shadow-sm
transition
hover:shadow-xl
">


<div

class="
flex
items-center
justify-between
"

>


<div

class="
flex
h-14
w-14
items-center
justify-center
rounded-2xl
bg-blue-100
text-3xl
"

>

{product.icon}

</div>


<Badge color="blue">

AI Product

</Badge>


</div>



<h3

class="
mt-8
text-2xl
font-black
text-slate-900
"

>

{product.name}

</h3>



<p

class="
mt-3
font-semibold
text-blue-600
"

>

{product.tagline}

</p>



<p

class="
mt-5
leading-8
text-slate-600
"

>

{product.description}

</p>




<h4

class="
mt-8
font-bold
"

>

Ideal For

</h4>


<ul class="mt-3 space-y-2">


{
product.audience.map(
(item:string)=>(

<li>

✓ {item}

</li>

))
}


</ul>




<h4

class="
mt-8
font-bold
"

>

Features

</h4>


<ul class="mt-3 space-y-2">


{
product.features.map(
(feature:string)=>(

<li>

✓ {feature}

</li>

))
}


</ul>




<h4

class="
mt-8
font-bold
"

>

Benefits

</h4>


<ul class="mt-3 space-y-2">


{
product.benefits.map(
(benefit:string)=>(

<li>

✓ {benefit}

</li>

))
}


</ul>




<h4

class="
mt-8
font-bold
"

>

Technology

</h4>


<div class="mt-3 flex flex-wrap gap-2">


{
product.technologies.map(
(tech:string)=>(


<span

class="
rounded-full
bg-slate-100
px-3
py-1
text-sm
"

>

{tech}

</span>


))
}


</div>



<a

href="/contact"

class="
mt-8
inline-block
rounded-xl
bg-blue-600
px-6
py-3
font-bold
text-white
"

>

{product.cta}

</a>


</div>
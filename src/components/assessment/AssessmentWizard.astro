---
import AssessmentProgress from "./AssessmentProgress.astro";

import BusinessProfileStep from "./BusinessProfileStep.astro";
import BusinessChallengesStep from "./BusinessChallengesStep.astro";
import TechnologyStep from "./TechnologyStep.astro";
import AIAdoptionStep from "./AIAdoptionStep.astro";
import GoalsStep from "./GoalsStep.astro";

import LeadCaptureForm from "./LeadCaptureForm.astro";
import AssessmentResults from "./AssessmentResults.astro";
---

<div id="assessment-wizard" class="mx-auto max-w-4xl">

  <!-- Progress Bar -->
  <div id="progress-container">
    <AssessmentProgress step={1} total={7} />
  </div>

  <!-- Wizard Steps -->
  <div id="steps-container">

    <!-- Step 1: Business Profile -->
    <div class="assessment-step" data-step="1">
      <BusinessProfileStep />
    </div>

    <!-- Step 2: Challenges -->
    <div class="assessment-step hidden" data-step="2">
      <BusinessChallengesStep />
    </div>

    <!-- Step 3: Technology -->
    <div class="assessment-step hidden" data-step="3">
      <TechnologyStep />
    </div>

    <!-- Step 4: AI Adoption -->
    <div class="assessment-step hidden" data-step="4">
      <AIAdoptionStep />
    </div>

    <!-- Step 5: Goals -->
    <div class="assessment-step hidden" data-step="5">
      <GoalsStep />
    </div>

    <!-- Step 6: Lead Capture -->
    <div class="assessment-step hidden" data-step="6">
      <LeadCaptureForm />
    </div>

    <!-- Step 7: Results -->
    <div class="assessment-step hidden" data-step="7">
      <AssessmentResults />
    </div>

  </div>

</div>

<script>
const STORAGE_KEY = "ragan_ai_assessment";
const TOTAL_STEPS = 7;
let currentStep = 1;

const steps = Array.from(
  document.querySelectorAll<HTMLElement>(".assessment-step")
);

const progress = document.getElementById("progress-container") as HTMLDivElement | null;

/* --- Answer Persistence --- */
function saveAnswer(questionId: string, answer: string): void {
  const answers = getAnswers();
  answers[questionId] = answer;
  localStorage.setItem(STORAGE_KEY, JSON.stringify(answers));
}

function getAnswers(): Record<string, string> {
  return JSON.parse(
    localStorage.getItem(STORAGE_KEY) ?? "{}"
  ) as Record<string, string>;
}

/* --- Navigation & Progress UI --- */
function showStep(step: number): void {
  steps.forEach((element) => {
    const stepNumber = Number(element.dataset.step ?? "0");
    if (stepNumber === step) {
      element.classList.remove("hidden");
    } else {
      element.classList.add("hidden");
    }
  });

  currentStep = step;
  updateProgress();
}

function updateProgress(): void {
  if (!progress) return;

  const percentage = Math.round((currentStep / TOTAL_STEPS) * 100);

  progress.innerHTML = `
<div class="mb-8">
  <div class="mb-3 flex justify-between">
    <span class="font-semibold text-slate-700">
      Step ${currentStep} of ${TOTAL_STEPS}
    </span>
    <span class="text-slate-500">
      ${percentage}%
    </span>
  </div>
  <div class="h-3 rounded-full bg-slate-200">
    <div
      class="h-3 rounded-full bg-blue-600 transition-all duration-300"
      style="width:${percentage}%"
    ></div>
  </div>
</div>
`;
}

/* --- Event Delegation --- */
document.addEventListener("click", (event: MouseEvent) => {
  const target = event.target as HTMLElement | null;
  if (!target) return;

  const answerButton = target.closest(".answer-option") as HTMLElement | null;

  if (answerButton) {
    const question = answerButton.closest(".assessment-question") as HTMLElement | null;

    if (question) {
      const questionId = question.dataset.questionId;
      const answer = answerButton.dataset.answer;

      if (questionId && answer) {
        saveAnswer(questionId, answer);
      }

      question
        .querySelectorAll<HTMLElement>(".answer-option")
        .forEach((item) => {
          item.classList.remove("border-blue-600", "bg-blue-50");
        });

      answerButton.classList.add("border-blue-600", "bg-blue-50");
    }
  }

  const navButton = target.closest("button") as HTMLButtonElement | null;
  if (!navButton) return;

  const buttonText = navButton.textContent?.trim() ?? "";

  switch (buttonText) {
    case "Continue":
      if (currentStep < 6) {
        showStep(currentStep + 1);
      }
      break;

    case "Back":
      if (currentStep > 1) {
        showStep(currentStep - 1);
      }
      break;
  }
});

/* --- Custom Event Listeners --- */
window.addEventListener("leadCaptured", () => {
  showStep(7);
});

window.addEventListener("resetAssessment", () => {
  localStorage.removeItem(STORAGE_KEY);
  currentStep = 1;
  showStep(1);
});

/* --- Init --- */
updateProgress();
</script>
---
import AssessmentQuestion from "./AssessmentQuestion.astro";

export interface Props {
  onNext?: string;
}

const { onNext = "#next" } = Astro.props;
---

<div class="space-y-12">

  <!-- Industry -->

  <AssessmentQuestion

    title="Which industry best describes your business?"

    subtitle="Choose the closest option."

    options={[

      "Manufacturing",

      "Construction",

      "Retail",

      "Healthcare",

      "Logistics",

      "Professional Services",

      "Education",

      "Others"

    ]}

  />


  <!-- Employees -->

  <AssessmentQuestion

    title="How many employees does your business have?"

    subtitle="This helps us recommend suitable AI approaches."

    options={[

      "1 - 10 employees",

      "11 - 50 employees",

      "51 - 200 employees",

      "201 - 500 employees",

      "500+ employees"

    ]}

  />


  <!-- Continue -->

  <div class="flex justify-end pt-8">

    <button

      id={onNext.replace("#","")}

      type="button"

      class="rounded-xl bg-blue-600 px-8 py-4 text-lg font-semibold text-white transition hover:bg-blue-700"

    >

      Continue

    </button>

  </div>


</div>
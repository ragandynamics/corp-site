<section

id="lead-capture"

class="rounded-3xl bg-white p-10 shadow"

>


<div class="text-center">


<h2 class="text-3xl font-bold text-slate-900">

Your AI Transformation Assessment Is Complete

</h2>



<p class="mt-4 text-lg leading-8 text-slate-600">

Thank you for completing your AI Transformation & ROI Assessment.

Based on your responses, we've identified several opportunities where AI can improve productivity, reduce costs and accelerate business growth.

Complete your details below to request a
<strong>complimentary AI Transformation Consultation</strong>.
During the consultation, one of our AI specialists will review your assessment results, discuss your business priorities and recommend practical AI initiatives tailored to your organisation.

</p>


</div>

<div class="mt-10 rounded-2xl border border-blue-100 bg-blue-50 p-6">

  <h3 class="text-lg font-bold text-slate-900">

    During Your Complimentary Consultation

  </h3>

  <div class="mt-5 grid gap-4 md:grid-cols-2 text-slate-700">

    <div>✓ Review your assessment results</div>

    <div>✓ Discuss your business priorities</div>

    <div>✓ Identify quick-win AI opportunities</div>

    <div>✓ Estimate business impact and ROI</div>

    <div>✓ Receive practical implementation recommendations</div>

    <div>✓ Build your AI transformation roadmap</div>

  </div>

</div>

<form

id="lead-form"

class="mt-10 space-y-6"

>


<!-- Name -->

<div>

<label

for="name"

class="mb-2 block font-semibold text-slate-700"

>

Name

</label>


<input

id="name"

name="name"

type="text"

required

placeholder="Your name"

class="w-full rounded-xl border border-slate-300 px-5 py-4 focus:border-blue-600 focus:outline-none"

/>

</div>



<!-- Company -->

<div>

<label

for="company"

class="mb-2 block font-semibold text-slate-700"

>

Company Name

</label>


<input

id="company"

name="company"

type="text"

required

placeholder="Company name"

class="w-full rounded-xl border border-slate-300 px-5 py-4 focus:border-blue-600 focus:outline-none"

/>

</div>



<!-- Email -->

<div>

<label

for="email"

class="mb-2 block font-semibold text-slate-700"

>

Business Email

</label>


<input

id="email"

name="email"

type="email"

required

placeholder="name@company.com"

class="w-full rounded-xl border border-slate-300 px-5 py-4 focus:border-blue-600 focus:outline-none"

/>

</div>



<!-- Phone -->

<div>

<label

for="phone"

class="mb-2 block font-semibold text-slate-700"

>

WhatsApp / Contact Number

</label>


<input

id="phone"

name="phone"

type="tel"

placeholder="+65"

class="w-full rounded-xl border border-slate-300 px-5 py-4 focus:border-blue-600 focus:outline-none"

/>

</div>



<!-- Consent -->


<label

class="flex items-start gap-3"

>


<input

id="consent"

type="checkbox"

required

class="mt-1 h-5 w-5"

/>


<span class="text-sm text-slate-600">

I agree that Ragan Dynamics may contact me regarding my AI Transformation Assessment, complimentary consultation and related AI business solutions.

</span>


</label>



<!-- Submit -->

<button

type="submit"

class="w-full rounded-xl bg-blue-600 px-8 py-4 text-lg font-bold text-white transition hover:bg-blue-700"

>

Request My Complimentary Consultation

</button>



<p

id="form-message"

class="hidden text-center text-sm"

>

</p>



</form>


</section>



<!-- All HTML above remains unchanged -->

<script>

const form = document.getElementById("lead-form") as HTMLFormElement | null;
const message = document.getElementById("form-message") as HTMLParagraphElement | null;

form?.addEventListener("submit", async (event: SubmitEvent) => {
  event.preventDefault();

  const submitButton = form.querySelector('button[type="submit"]') as HTMLButtonElement | null;

  if (!submitButton) return;

  submitButton.disabled = true;
  submitButton.innerText = "Submitting Your Request...";

  try {
    const answers = JSON.parse(
      localStorage.getItem("ragan_ai_assessment") ?? "{}"
    ) as Record<string, string>;

    const name = (document.getElementById("name") as HTMLInputElement).value.trim();
    const company = (document.getElementById("company") as HTMLInputElement).value.trim();
    const email = (document.getElementById("email") as HTMLInputElement).value.trim();
    const phone = (document.getElementById("phone") as HTMLInputElement).value.trim();

    const formData = {
      name,
      company,
      email,
      phone,
      answers
    };

    const response = await fetch("/api/assessment-lead", {
      method: "POST",
      headers: {
        "Content-Type": "application/json"
      },
      body: JSON.stringify(formData)
    });

    if (!response.ok) {
      throw new Error("Submission failed");
    }

    /* Store locally */
    localStorage.setItem("ragan_ai_lead", JSON.stringify(formData));

    /* Notify wizard */
    window.dispatchEvent(new CustomEvent("leadCaptured"));

    const wizardStep = document.querySelector('[data-step="7"]') as HTMLElement | null;

    document.querySelectorAll<HTMLElement>(".assessment-step").forEach((item) => {
      item.classList.add("hidden");
    });

    wizardStep?.classList.remove("hidden");
  } catch (error) {
    console.error(error);

    if (message) {
      message.classList.remove("hidden");
      message.className = "text-center text-sm text-red-600";
      message.textContent = "We couldn't submit your consultation request. Please try again in a few moments.";
    }

    submitButton.disabled = false;
    submitButton.innerText = "Request My Complimentary Consultation";
  }
});

</script>
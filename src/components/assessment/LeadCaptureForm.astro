<section

id="lead-capture"

class="rounded-3xl bg-white p-10 shadow"

>


<div class="text-center">


<h2 class="text-3xl font-bold text-slate-900">

Your AI Assessment Is Ready

</h2>



<p class="mt-4 text-slate-600">

Enter your details to receive your personalised AI recommendations.

</p>


</div>



<form

id="lead-form"

class="mt-10 space-y-6"

>


<!-- Name -->

<div>

<label

for="name"

class="mb-2 block font-semibold text-slate-700"

>

Name

</label>


<input

id="name"

name="name"

type="text"

required

placeholder="Your name"

class="w-full rounded-xl border border-slate-300 px-5 py-4 focus:border-blue-600 focus:outline-none"

/>

</div>



<!-- Company -->

<div>

<label

for="company"

class="mb-2 block font-semibold text-slate-700"

>

Company Name

</label>


<input

id="company"

name="company"

type="text"

required

placeholder="Company name"

class="w-full rounded-xl border border-slate-300 px-5 py-4 focus:border-blue-600 focus:outline-none"

/>

</div>



<!-- Email -->

<div>

<label

for="email"

class="mb-2 block font-semibold text-slate-700"

>

Business Email

</label>


<input

id="email"

name="email"

type="email"

required

placeholder="name@company.com"

class="w-full rounded-xl border border-slate-300 px-5 py-4 focus:border-blue-600 focus:outline-none"

/>

</div>



<!-- Phone -->

<div>

<label

for="phone"

class="mb-2 block font-semibold text-slate-700"

>

WhatsApp / Contact Number

</label>


<input

id="phone"

name="phone"

type="tel"

placeholder="+65"

class="w-full rounded-xl border border-slate-300 px-5 py-4 focus:border-blue-600 focus:outline-none"

/>

</div>



<!-- Consent -->


<label

class="flex items-start gap-3"

>


<input

id="consent"

type="checkbox"

required

class="mt-1 h-5 w-5"

/>


<span class="text-sm text-slate-600">

I agree to be contacted regarding AI consultation and business solutions.

</span>


</label>



<!-- Submit -->

<button

type="submit"

class="w-full rounded-xl bg-blue-600 px-8 py-4 text-lg font-bold text-white transition hover:bg-blue-700"

>

View My AI Results

</button>



<p

id="form-message"

class="hidden text-center text-sm"

>

</p>



</form>


</section>



<script>


const form =

document.getElementById(

"lead-form"

);



const message =

document.getElementById(

"form-message"

);



form?.addEventListener(

"submit",

async(event)=>{


event.preventDefault();



const button =

form.querySelector(

"button"

);



button.disabled = true;


button.innerText =
"Processing...";



try{


const answers = JSON.parse(

localStorage.getItem(

"ragan_ai_assessment"

)

||

"{}"

);



const formData = {


name:

document.getElementById(

"name"

).value,


company:

document.getElementById(

"company"

).value,


email:

document.getElementById(

"email"

).value,


phone:

document.getElementById(

"phone"

).value,


answers

};




const response = await fetch(

"/api/assessment-lead",

{


method:"POST",


headers:

{


"Content-Type":

"application/json"


},


body:

JSON.stringify(

formData

)


}

);



if(!response.ok)

{

throw new Error(

"Submission failed"

);

}



/*
Store lead locally

for reference

*/

localStorage.setItem(

"ragan_ai_lead",

JSON.stringify(

formData

)

);



/*
Move to results

*/

window.dispatchEvent(

new CustomEvent(

"leadCaptured"

)

);



const wizardStep =

document.querySelector(

'[data-step="7"]'

);



document

.querySelectorAll(

".assessment-step"

)

.forEach(

(item)=>{


item.classList.add(

"hidden"

);


}

);



wizardStep?.classList.remove(

"hidden"

);



}


catch(error){


console.error(

error

);



if(message)

{


message.classList.remove(

"hidden"

);


message.className =

"text-center text-sm text-red-600";



message.innerText =

"Unable to submit your details. Please try again.";

}



button.disabled=false;


button.innerText =

"View My AI Results";


}



});


</script>
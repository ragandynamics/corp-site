<section class="rounded-3xl bg-white p-10 shadow-lg">

  <!-- ====================================================== -->
  <!-- Header -->
  <!-- ====================================================== -->

  <div class="text-center">

    <div class="mx-auto flex h-20 w-20 items-center justify-center rounded-full bg-green-100">

      <svg
        xmlns="http://www.w3.org/2000/svg"
        class="h-10 w-10 text-green-600"
        fill="none"
        viewBox="0 0 24 24"
        stroke="currentColor"
      >

        <path
          stroke-linecap="round"
          stroke-linejoin="round"
          stroke-width="2"
          d="M5 13l4 4L19 7"
        />

      </svg>

    </div>

    <h2 class="mt-6 text-4xl font-black text-slate-900">

      Your AI Transformation Opportunity Report

    </h2>

    <p class="mt-4 text-lg text-slate-600">

      Based on your responses, we analysed your current
      AI readiness and identified practical opportunities
      to improve productivity, reduce costs and accelerate
      business growth.

    </p>

  </div>

  <!-- ====================================================== -->
  <!-- Summary Cards -->
  <!-- ====================================================== -->

  <div class="mt-12 grid gap-8 lg:grid-cols-3">

    <!-- Score -->

    <div class="rounded-2xl border border-blue-200 bg-blue-50 p-8 text-center">

      <div class="text-sm font-semibold uppercase tracking-wider text-blue-700">

        AI Readiness Score

      </div>

      <div
        id="readiness-score"
        class="mt-4 text-6xl font-black text-blue-600"
      >

        --

      </div>

      <p
        id="maturity-level"
        class="mt-4 text-lg font-semibold text-slate-700"
      >

      </p>

    </div>

    <!-- Priority -->

    <div class="rounded-2xl border border-slate-200 p-8">

      <h3 class="text-xl font-bold text-slate-900">

        Top Priority

      </h3>

      <p
        id="top-priority"
        class="mt-4 leading-7 text-slate-600"
      >

      </p>

    </div>

    <!-- Timeline -->

    <div class="rounded-2xl border border-slate-200 p-8">

      <h3 class="text-xl font-bold text-slate-900">

        Suggested Timeline

      </h3>

      <p
        id="timeline"
        class="mt-4 leading-7 text-slate-600"
      >

      </p>

    </div>

  </div>

  <!-- ====================================================== -->
  <!-- Recommendations -->
  <!-- ====================================================== -->

  <div class="mt-14">

    <h3 class="text-3xl font-bold text-slate-900">

      Recommended AI Initiatives

    </h3>

    <p class="mt-3 text-slate-600">

      These recommendations are tailored based on your
      assessment responses.

    </p>

    <div
      id="recommendations"
      class="mt-8 grid gap-6 md:grid-cols-2"
    >

      <!-- Generated dynamically -->

    </div>

  </div>

  <!-- ====================================================== -->
  <!-- Suggested Services -->
  <!-- ====================================================== -->

  <div class="mt-14">

    <h3 class="text-3xl font-bold text-slate-900">

      How Ragan Dynamics Can Help

    </h3>

    <div
      id="recommended-services"
      class="mt-8 grid gap-6 md:grid-cols-3"
    >

      <!-- Generated dynamically -->

    </div>

  </div>

  <!-- ====================================================== -->
  <!-- Next Steps -->
  <!-- ====================================================== -->

  <div class="mt-14 rounded-3xl bg-slate-900 p-10 text-center">

    <h3 class="text-3xl font-bold text-white">

      Ready to Transform Your Business?

    </h3>

    <p class="mt-4 text-lg leading-8 text-slate-300">

      Discuss your assessment results with an AI consultant
      and receive practical recommendations tailored to
      your business goals.

    </p>

    <div class="mt-8 flex flex-wrap justify-center gap-4">

      <a
        href="/contact"
        class="rounded-xl bg-blue-600 px-8 py-4 text-lg font-bold text-white transition hover:bg-blue-700"
      >

        Book an AI Discovery Session

      </a>

      <button
        id="restart-assessment"
        class="rounded-xl border border-white px-8 py-4 text-lg font-semibold text-white transition hover:bg-white hover:text-slate-900"
      >

        Start Assessment Again

      </button>

    </div>

  </div>

</section>
<!-- All HTML above remains unchanged -->

<script>

interface AssessmentAnswers {
  industry?: string;
  companySize?: string;
  challenges?: string;
  technology?: string;
  aiAdoption?: string;
  goals?: string;
}

interface Recommendation {
  title: string;
  description: string;
}

interface ServiceRecommendation {
  title: string;
  description: string;
}

const STORAGE_KEY = "ragan_ai_assessment";

/* ======================================================
   DOM Elements
====================================================== */

const scoreElement = document.getElementById("readiness-score") as HTMLElement | null;
const maturityElement = document.getElementById("maturity-level") as HTMLElement | null;
const priorityElement = document.getElementById("top-priority") as HTMLElement | null;
const timelineElement = document.getElementById("timeline") as HTMLElement | null;
const recommendationsElement = document.getElementById("recommendations") as HTMLElement | null;
const servicesElement = document.getElementById("recommended-services") as HTMLElement | null;
const restartButton = document.getElementById("restart-assessment") as HTMLButtonElement | null;

/* ======================================================
   Load Answers
====================================================== */

function loadAnswers(): AssessmentAnswers {
  return JSON.parse(
    localStorage.getItem(STORAGE_KEY) ?? "{}"
  ) as AssessmentAnswers;
}

/* ======================================================
   AI Readiness Score
====================================================== */

function calculateScore(answers: AssessmentAnswers): number {
  let score = 20;

  if (answers.industry) score += 10;
  if (answers.companySize) score += 10;
  if (answers.technology) score += 15;
  if (answers.aiAdoption) score += 20;
  if (answers.challenges) score += 20;
  if (answers.goals) score += 25;

  return Math.min(score, 100);
}

/* ======================================================
   AI Maturity
====================================================== */

function getMaturityLevel(score: number): string {
  if (score < 30) return "AI Beginner";
  if (score < 60) return "AI Explorer";
  if (score < 80) return "AI Adopter";
  return "AI Ready";
}

/* ======================================================
   Suggested Timeline
====================================================== */

function getTimeline(score: number): string {
  if (score < 30) return "Begin with one quick-win AI project over the next 30–60 days.";
  if (score < 60) return "Implement two or three AI initiatives over the next 3 months.";
  return "Develop a structured AI roadmap over the next 6–12 months.";
}

/* ======================================================
   Top Priority
====================================================== */

function getPriority(answers: AssessmentAnswers): string {
  switch (answers.challenges) {
    case "manual-processes":
      return "Automate repetitive manual work.";
    case "customer-service":
      return "Deploy an AI customer assistant.";
    case "sales":
      return "Use AI to improve sales and marketing.";
    case "reporting":
      return "Implement AI-powered dashboards and analytics.";
    case "staff-productivity":
      return "Provide AI assistants for employees.";
    default:
      return "Identify high-impact AI opportunities.";
  }
}

/* ======================================================
   AI Recommendations
====================================================== */

function getRecommendations(answers: AssessmentAnswers): Recommendation[] {
  const recommendations: Recommendation[] = [];

  if (answers.challenges === "manual-processes") {
    recommendations.push({
      title: "Workflow Automation",
      description: "Automate repetitive tasks using AI and business workflow automation."
    });
  }

  if (answers.challenges === "customer-service") {
    recommendations.push({
      title: "AI Customer Assistant",
      description: "Provide 24/7 customer support using conversational AI."
    });
  }

  if (answers.challenges === "sales") {
    recommendations.push({
      title: "AI Sales Assistant",
      description: "Generate leads, qualify prospects and personalise customer engagement."
    });
  }

  if (answers.goals === "productivity") {
    recommendations.push({
      title: "Employee AI Copilot",
      description: "Increase staff productivity using AI-powered assistants."
    });
  }

  if (answers.goals === "cost-reduction") {
    recommendations.push({
      title: "Business Process Optimisation",
      description: "Reduce operational costs through AI-driven automation."
    });
  }

  recommendations.push({
    title: "AI Strategy Roadmap",
    description: "Develop a practical AI roadmap aligned with your business objectives."
  });

  return recommendations;
}

/* ======================================================
   Suggested Services
====================================================== */

function getServices(answers: AssessmentAnswers): ServiceRecommendation[] {
  const services: ServiceRecommendation[] = [
    {
      title: "AI Strategy",
      description: "Define an AI roadmap aligned with your business."
    },
    {
      title: "AI Automation",
      description: "Automate manual business processes."
    },
    {
      title: "AI Copilot",
      description: "Improve employee productivity using AI assistants."
    }
  ];

  if (answers.challenges === "customer-service") {
    services.push({
      title: "AI Customer Support",
      description: "Deploy AI-powered customer service."
    });
  }

  return services;
}

/* ======================================================
   Render Results
====================================================== */

function renderResults(): void {
  const answers = loadAnswers();
  const score = calculateScore(answers);

  if (scoreElement) scoreElement.textContent = score.toString();
  if (maturityElement) maturityElement.textContent = getMaturityLevel(score);
  if (priorityElement) priorityElement.textContent = getPriority(answers);
  if (timelineElement) timelineElement.textContent = getTimeline(score);

  if (recommendationsElement) {
    recommendationsElement.innerHTML = "";
    getRecommendations(answers).forEach((item) => {
      recommendationsElement.insertAdjacentHTML(
        "beforeend",
        `
        <div class="rounded-2xl border border-slate-200 p-6 hover:border-blue-400 transition">
          <h4 class="text-xl font-bold text-slate-900">${item.title}</h4>
          <p class="mt-3 leading-7 text-slate-600">${item.description}</p>
        </div>
        `
      );
    });
  }

  if (servicesElement) {
    servicesElement.innerHTML = "";
    getServices(answers).forEach((service) => {
      servicesElement.insertAdjacentHTML(
        "beforeend",
        `
        <div class="rounded-2xl border border-slate-200 bg-slate-50 p-6">
          <h4 class="text-lg font-bold text-slate-900">${service.title}</h4>
          <p class="mt-3 leading-7 text-slate-600">${service.description}</p>
        </div>
        `
      );
    });
  }
}

/* ======================================================
   Restart Assessment
====================================================== */

restartButton?.addEventListener("click", () => {
  localStorage.removeItem(STORAGE_KEY);
  window.dispatchEvent(new CustomEvent("resetAssessment"));
});

/* ======================================================
   Initialise
====================================================== */

renderResults();

</script>
---

const {
service
}=Astro.props;

---

<div

class="
rounded-3xl
border
border-slate-200
bg-white
p-8
shadow-sm
"


>


<div class="text-4xl">

{service.icon}

</div>


<h3

class="
mt-6
text-2xl
font-black
"

>

{service.title}

</h3>


<p class="mt-4 text-slate-600">

{service.description}

</p>



<ul class="mt-6 space-y-2">


{
service.features.map(
(feature:string)=>(

<li>

✓ {feature}

</li>

))
}


</ul>



<a

href="/contact"

class="
mt-8
inline-block
rounded-xl
bg-blue-600
px-6
py-3
text-white
"

>

{service.cta}

</a>


</div>
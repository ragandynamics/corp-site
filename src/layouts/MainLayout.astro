---
import "../styles/global.css";


import Navbar from "../components/layout/Navbar.astro";

import Footer from "../components/layout/Footer.astro";

import MobileMenu from "../components/layout/MobileMenu.astro";

import SEOHead from "../components/layout/SEOHead.astro";

import CloudflareAnalytics 
from "../components/analytics/CloudflareAnalytics.astro";


export interface Props {

title:string;

description:string;

image?:string;

}


const {

title,

description,

image

}=Astro.props;


const analyticsToken =
import.meta.env.PUBLIC_CF_ANALYTICS_TOKEN;

---

<!doctype html>

<html lang="en">


<head>


<meta charset="UTF-8" />


<meta

name="viewport"

content="width=device-width, initial-scale=1.0"

/>


<SEOHead

title={title}

description={description}

image={image}

/>



{
analyticsToken &&

<CloudflareAnalytics

token={analyticsToken}

/>

}



<link

rel="icon"

href="/favicon.svg"

/>


</head>



<body

class="
min-h-screen
bg-white
text-slate-600
antialiased
"


>


<Navbar />


<MobileMenu />


<main>

<slot />

</main>


<Footer />



</body>


</html>